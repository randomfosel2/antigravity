      <aliases enabled='yes' />
      <column caption='AR country' datatype='string' name='[AR_country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column caption='Top &amp; Bottom' datatype='boolean' name='[Calculation_1080334972030976]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Score A (Integer)]), &apos;desc&apos;) &lt;= [Parameters].[매개 변수 1]&#13;&#10;OR&#13;&#10;RANK(SUM([Score A (Integer)]), &apos;asc&apos;) &lt;= [Parameters].[매개 변수 1]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='측정값 필드' datatype='integer' name='[Calculation_1080334976438273]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='case [Parameters].[매개 변수 2]&#13;&#10;WHEN  &apos;Rank 2019&apos; then sum([Rank 2019])&#13;&#10;WHEN  &apos;Rank 2020&apos; then sum([Rank2020])&#13;&#10;WHEN  &apos;Score&apos; then SUM([Score A (Integer)])&#13;&#10;WHEN  &apos;Progression RANK&apos; then sum([Progression RANK])&#13;&#10;else null end' />
      </column>
